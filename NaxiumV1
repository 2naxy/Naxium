    local function setupChatDetection(p)
        p.Chatted:Connect(function(msg)
            if string.find(msg,"/e nx_ping") or string.find(msg,"/e nx_pong") then
                markNaxiumUser(p)
                if string.find(msg,"/e nx_ping") and p~=player then
                    task.wait(math.random(1,3)*0.1)
                    pcall(function()
                        if S.TCS.ChatVersion==Enum.ChatVersion.TextChatService then
                            S.TCS.TextChannels.RBXGeneral:SendAsync("/e nx_pong")
                        else
                            game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer("/e nx_pong","All")
                        end
                    end)
                end
            end
        end)
    end
