    local function decodeData(str)
        local ok2, t = pcall(function() return S.Http:JSONDecode(str) end)
        if not ok2 or type(t)~="table" then return {} end
        local res = {}
        for k, v in pairs(t) do
            if type(v)=="table" then
                if     v._c then res[k]=Color3.new(v.r,v.g,v.b)
                elseif v._e then res[k]=v.n
                else             res[k]=v end
            else res[k]=v end
        end
