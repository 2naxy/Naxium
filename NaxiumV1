-- ============================================================
local function VerifyKeyAuth(user_key, status_label)
    local player_hwid = ""
    if gethwid then
        player_hwid = gethwid()
    else
        player_hwid = game:GetService("RbxAnalyticsService"):GetClientId()
    end

    if status_label then status_label.Text = "Initializing KeyAuth Session..." end

    -- Step 1: Initialize
    local init_req = request({
        Url = "https://keyauth.win/api/1.2/",
        Method = "POST",
        Headers = { ["Content-Type"] = "application/x-www-form-urlencoded" },
        Body = "type=init&name=" .. app_name .. "&ownerid=" .. owner_id .. "&version=" .. app_version
    })
    
    local init_data = HttpService:JSONDecode(init_req.Body)
    if not init_data.success then
        warn("KeyAuth Init Failed: " .. init_data.message)
        if status_label then 
            status_label.Text = "Init Failed: " .. init_data.message
            status_label.TextColor3 = Color3.fromRGB(210, 65, 65) 
            task.wait(2)
        end
        return false
    end
    
    local session_id = init_data.sessionid

    if status_label then status_label.Text = "Fetching Live Stats..." end

    -- Step 1.5: Fetch Stats
    local stats_req = request({
        Url = "https://keyauth.win/api/1.2/",
        Method = "POST",
        Headers = { ["Content-Type"] = "application/x-www-form-urlencoded" },
        Body = "type=fetchStats&sessionid=" .. session_id .. "&name=" .. app_name .. "&ownerid=" .. owner_id
    })
    
    local stats_data = HttpService:JSONDecode(stats_req.Body)
    if stats_data.success and stats_data.appinfo then
        _G.NaxiumOnlineUsers = stats_data.appinfo.numOnlineUsers or "0"
    else
        _G.NaxiumOnlineUsers = "0"
    end

    if status_label then status_label.Text = "Validating License Key..." end

    -- Step 2: License Check
    local license_req = request({
        Url = "https://keyauth.win/api/1.2/",
        Method = "POST",
        Headers = { ["Content-Type"] = "application/x-www-form-urlencoded" },
        Body = "type=license&key=" .. user_key .. "&hwid=" .. player_hwid .. "&sessionid=" .. session_id .. "&name=" .. app_name .. "&ownerid=" .. owner_id
    })

    local license_data = HttpService:JSONDecode(license_req.Body)
    if license_data.success then
        print("KeyAuth: Authentication Successful! Welcome back.")
        pcall(function()
            if license_data.info and license_data.info.subscriptions and license_data.info.subscriptions[1] then
                _G.NaxiumExpiry = tonumber(license_data.info.subscriptions[1].expiry)
            end
        end)
        if status_label then 
            status_label.Text = "Authentication Successful!" 
            status_label.TextColor3 = Color3.fromRGB(65, 190, 105)
            task.wait(0.5)
        end
        return true
    else
        warn("KeyAuth: Invalid Key! (" .. license_data.message .. ")")
        if status_label then 
            status_label.Text = "Invalid Key: " .. license_data.message
            status_label.TextColor3 = Color3.fromRGB(210, 65, 65)
            task.wait(2.5)
        end
        return false
    end
end

